# ─── ai-org-blueprint env template ───────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real secrets.

# ─── LLM runner (default: mock for offline demo) ─────────────────────────
# Choices: mock | api | claude_code
# - mock        → no API key needed, deterministic responses for testing
# - api         → calls Anthropic API directly (set ANTHROPIC_API_KEY)
# - claude_code → opt-in: uses Claude Code CLI via sidecar (see docker-compose.full.yml)
LLM_RUNNER=mock

# Required if LLM_RUNNER=api or claude_code
ANTHROPIC_API_KEY=

# Model selection
LLM_MODEL=claude-haiku-4-5-20251001

# ─── Brain storage ───────────────────────────────────────────────────────
BRAIN_DB_PATH=./data/brain.db

# ─── Demo settings ───────────────────────────────────────────────────────
# Owner name shown in agent prompts (replace with your name when forking)
OWNER_NAME=Demo User

# Optional: HTTP port for the Brain API
BRAIN_HTTP_PORT=8765
